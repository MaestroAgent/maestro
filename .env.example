# Required
ANTHROPIC_API_KEY=sk-ant-...

# For Telegram bot (required if running telegram service)
TELEGRAM_BOT_TOKEN=...

# For cloning private GitHub repos (optional)
# Create a classic token at: https://github.com/settings/tokens
# Select the "repo" scope for full access to your repositories
GITHUB_TOKEN=ghp_...

# Optional
PORT=3000
LOG_LEVEL=info
DAILY_BUDGET_USD=20
