# Required
ANTHROPIC_API_KEY=sk-ant-...

# For Telegram bot (required if running telegram service)
TELEGRAM_BOT_TOKEN=...

# For cloning private GitHub repos (optional)
# Create a classic token at: https://github.com/settings/tokens
# Select the "repo" scope for full access to your repositories
GITHUB_TOKEN=ghp_...

# Optional
PORT=3000
LOG_LEVEL=info
DAILY_BUDGET_USD=20

# API Authentication
# Set to false to disable API key authentication (useful for local development)
MAESTRO_API_AUTH_ENABLED=true
# Seed an initial API key on first run (format: msk_<64 hex chars>)
# Generate with: openssl rand -hex 32 | sed 's/^/msk_/'
MAESTRO_API_KEY=
# Comma-separated list of allowed CORS origins (default: * allows all)
MAESTRO_CORS_ORIGINS=http://localhost:3000

# User Allowlists (empty = allow all users)
# Comma-separated list of authorized Telegram chat IDs
MAESTRO_TELEGRAM_ALLOWED_USERS=
# Comma-separated list of authorized Slack user IDs
MAESTRO_SLACK_ALLOWED_USERS=

# Rate Limiting
# Set to false to disable rate limiting
MAESTRO_RATE_LIMIT_ENABLED=true
# Requests per minute for /chat endpoint (default: 20)
MAESTRO_RATE_LIMIT_CHAT=20

# Claude Code Restrictions
# Comma-separated list of tools Claude Code CLI is allowed to use
# Default is read-only tools: Read,Glob,Grep
# To enable more tools, add them here (e.g., Read,Glob,Grep,Bash,Edit,Write)
MAESTRO_CLAUDE_CODE_ALLOWED_TOOLS=Read,Glob,Grep
