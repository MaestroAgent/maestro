{
  "name": "maestro",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/index.ts cli",
    "api": "tsx src/index.ts api",
    "slack": "tsx src/index.ts slack",
    "build": "tsc",
    "build:dashboard": "cd dashboard && npm run build",
    "build:all": "npm run build && npm run build:dashboard",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hono/node-server": "^1.19.9",
    "@hono/node-ws": "^1.3.0",
    "@slack/bolt": "^4.6.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "faiss-node": "^0.5.1",
    "grammy": "^1.35.0",
    "hono": "^4.11.5",
    "playwright": "^1.58.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.12.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "svgo": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
